+from __future__ import annotations
+
+import importlib.util
+import pathlib
+
+import torch
+
+
+def _load_t1_symmetry_module():
+    module_path = (
+        pathlib.Path(__file__).resolve().parents[1]
+        / "isaaclab_tasks"
+        / "manager_based"
+        / "locomotion"
+        / "velocity"
+        / "mdp"
+        / "symmetry"
+        / "t1.py"
+    )
+    spec = importlib.util.spec_from_file_location("t1_symmetry_module", module_path)
+    module = importlib.util.module_from_spec(spec)
+    assert spec.loader is not None
+    spec.loader.exec_module(module)
+    return module
+
+
+def _load_t1_half_body_mapping_module():
+    module_path = (
+        pathlib.Path(__file__).resolve().parents[1]
+        / "isaaclab_tasks"
+        / "manager_based"
+        / "locomotion"
+        / "velocity"
+        / "config"
+        / "t1"
+        / "mdp"
+        / "half_body_mapping.py"
+    )
+    spec = importlib.util.spec_from_file_location("t1_half_body_mapping_module", module_path)
+    module = importlib.util.module_from_spec(spec)
+    assert spec.loader is not None
+    spec.loader.exec_module(module)
+    return module
+
+
+t1 = _load_t1_symmetry_module()
+half_body = _load_t1_half_body_mapping_module()
+
+
+def test_t1_joint_mirror_is_involution():
+    joint_tensor = torch.randn(16, t1.JOINT_COUNT)
+    torch.testing.assert_close(t1.mirror_joint_tensor(t1.mirror_joint_tensor(joint_tensor)), joint_tensor)
+
+
+def test_t1_policy_mirror_supports_phase_clock():
+    obs = torch.randn(8, t1.POLICY_OBS_WITH_PHASE_SIZE)
+    torch.testing.assert_close(t1.mirror_policy_obs(t1.mirror_policy_obs(obs)), obs)
+
+
+def test_t1_velocity_command_mirror_is_involution():
+    command = torch.randn(32, 3)
+    torch.testing.assert_close(t1.mirror_velocity_command(t1.mirror_velocity_command(command)), command)
+
+
+def test_t1_symmetric_joint_pose_is_fixed_point():
+    joint_tensor = torch.randn(4, t1.JOINT_COUNT)
+    symmetric_joint_tensor = 0.5 * (joint_tensor + t1.mirror_joint_tensor(joint_tensor))
+    torch.testing.assert_close(t1.mirror_joint_tensor(symmetric_joint_tensor), symmetric_joint_tensor)
+
+
+def test_t1_half_body_mapping_uses_delayed_right_drive_and_left_residual():
+    raw_actions = torch.zeros(2, t1.JOINT_COUNT)
+    delayed_drive = torch.zeros_like(raw_actions)
+    raw_actions[:, half_body.RIGHT_AND_CENTER_INDICES] = 0.25
+    raw_actions[:, half_body.LEFT_INDICES] = 1.0
+    delayed_drive[:, 6] = 0.4
+    delayed_drive[:, 7] = 0.5
+    delayed_drive[:, 17] = -0.6
+    full_actions = half_body.half_body_raw_actions(raw_actions, delayed_drive, residual_scale=0.08)
+    expected = half_body.mirror_joint_tensor(delayed_drive)
+    torch.testing.assert_close(full_actions[:, half_body.RIGHT_AND_CENTER_INDICES], raw_actions[:, half_body.RIGHT_AND_CENTER_INDICES])
+    torch.testing.assert_close(full_actions[:, half_body.LEFT_INDICES], expected[:, half_body.LEFT_INDICES] + 0.08)
+
+
+def test_t1_half_body_mapping_mirrors_left_right_joint_signs():
+    delayed_drive = torch.zeros(1, t1.JOINT_COUNT)
+    delayed_drive[0, 6] = 0.2
+    delayed_drive[0, 7] = 0.3
+    delayed_drive[0, 9] = 0.4
+    delayed_drive[0, 18] = 0.5
+    delayed_drive[0, 19] = 0.6
+    delayed_drive[0, 22] = 0.7
+    full_actions = half_body.half_body_raw_actions(torch.zeros_like(delayed_drive), delayed_drive, residual_scale=0.0)
+    torch.testing.assert_close(full_actions[0, 2], torch.tensor(0.2))
+    torch.testing.assert_close(full_actions[0, 3], torch.tensor(-0.3))
+    torch.testing.assert_close(full_actions[0, 5], torch.tensor(-0.4))
+    torch.testing.assert_close(full_actions[0, 12], torch.tensor(-0.5))
+    torch.testing.assert_close(full_actions[0, 13], torch.tensor(-0.6))
+    torch.testing.assert_close(full_actions[0, 16], torch.tensor(-0.7))
