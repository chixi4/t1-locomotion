@@ -0,0 +1,202 @@
+from __future__ import annotations
+
+from collections.abc import Sequence
+from typing import Any
+
+import torch
+
+from isaaclab.envs import ManagerBasedRLEnv
+from isaaclab.managers import SceneEntityCfg
+
+from isaaclab_tasks.manager_based.locomotion.velocity.config.t1.mdp import (
+    full_body_symmetry,
+    symmetry_clock,
+    velocity_metrics,
+)
+
+
+class T1PhaseRecurrentEnv(ManagerBasedRLEnv):
+    def __init__(self, cfg, render_mode: str | None = None, **kwargs):
+        self._gait_phase_offset = torch.zeros(cfg.scene.num_envs, device=cfg.sim.device)
+        super().__init__(cfg=cfg, render_mode=render_mode, **kwargs)
+        self._foot_asset_cfg = self._make_scene_entity_cfg("robot")
+        self._foot_sensor_cfg = self._make_scene_entity_cfg("contact_forces")
+        self._init_symmetry_metric_buffers()
+        velocity_metrics.init_velocity_metric_buffers(self)
+        all_env_ids = torch.arange(self.num_envs, device=self.device)
+        velocity_metrics.assign_standalone_gait_phase_offsets(self, all_env_ids)
+
+    def reset(
+        self, seed: int | None = None, env_ids: Sequence[int] | None = None, options: dict[str, Any] | None = None
+    ):
+        return super().reset(seed=seed, env_ids=env_ids, options=options)
+
+    def step(self, action: torch.Tensor):
+        self._simulate_physics(action)
+        self._update_after_physics()
+        self._update_symmetry_metrics()
+        velocity_metrics.update_velocity_metrics(self, self._foot_asset_cfg, self._foot_sensor_cfg)
+        reset_env_ids = self.reset_buf.nonzero(as_tuple=False).squeeze(-1)
+        if reset_env_ids.numel() > 0:
+            self._reset_envs(reset_env_ids)
+        self._update_commands_and_observations()
+        return self.obs_buf, self.reward_buf, self.reset_terminated, self.reset_time_outs, self.extras
+
+    def _reset_idx(self, env_ids: Sequence[int]):
+        env_ids_tensor = self._to_env_tensor(env_ids)
+        symmetry_logs = self._collect_symmetry_logs(env_ids_tensor)
+        velocity_logs = velocity_metrics.collect_velocity_metric_logs(self, env_ids_tensor)
+        super()._reset_idx(env_ids_tensor)
+        self.extras["log"].update(symmetry_logs)
+        self.extras["log"].update(velocity_logs)
+        self._clear_metric_buffers(env_ids_tensor)
+
+    def _simulate_physics(self, action: torch.Tensor) -> None:
+        self.action_manager.process_action(action.to(self.device))
+        self.recorder_manager.record_pre_step()
+        is_rendering = self.sim.has_gui() or self.sim.has_rtx_sensors()
+        for _ in range(self.cfg.decimation):
+            self._sim_step_counter += 1
+            self.action_manager.apply_action()
+            self.scene.write_data_to_sim()
+            self.sim.step(render=False)
+            self.recorder_manager.record_post_physics_decimation_step()
+            if self._sim_step_counter % self.cfg.sim.render_interval == 0 and is_rendering:
+                self.sim.render()
+            self.scene.update(dt=self.physics_dt)
+
+    def _update_after_physics(self) -> None:
+        self.episode_length_buf += 1
+        self.common_step_counter += 1
+        self.reset_buf = self.termination_manager.compute()
+        self.reset_terminated = self.termination_manager.terminated
+        self.reset_time_outs = self.termination_manager.time_outs
+        self.reward_buf = self.reward_manager.compute(dt=self.step_dt)
+        if len(self.recorder_manager.active_terms) == 0:
+            return
+        self.obs_buf = self.observation_manager.compute()
+        self.recorder_manager.record_post_step()
+
+    def _reset_envs(self, reset_env_ids: torch.Tensor) -> None:
+        self.recorder_manager.record_pre_reset(reset_env_ids)
+        self._reset_idx(reset_env_ids)
+        if self.sim.has_rtx_sensors() and self.cfg.num_rerenders_on_reset > 0:
+            for _ in range(self.cfg.num_rerenders_on_reset):
+                self.sim.render()
+        self.recorder_manager.record_post_reset(reset_env_ids)
+
+    def _update_commands_and_observations(self) -> None:
+        self.command_manager.compute(dt=self.step_dt)
+        if "interval" in self.event_manager.available_modes:
+            self.event_manager.apply(mode="interval", dt=self.step_dt)
+        self.obs_buf = self.observation_manager.compute(update_history=True)
+
+    def _update_symmetry_metrics(self) -> None:
+        contact_force = symmetry_clock.contact_force_norm(self, self._foot_sensor_cfg)
+        contacts = (contact_force > 1.0).float()
+        self._stance_time += contacts * self.step_dt
+        self._ground_impulse += contact_force * self.step_dt
+        _, _, left_swing, right_swing, move_mask = symmetry_clock.phase_weights(self, command_name="base_velocity")
+        swing_weight = torch.stack((left_swing, right_swing), dim=1) * move_mask.unsqueeze(1) * self.step_dt
+        self._swing_height_sum += symmetry_clock.foot_heights(self, self._foot_asset_cfg) * swing_weight
+        self._swing_weight_sum += swing_weight
+        self._moving_step_weight += move_mask
+        foot_forward = symmetry_clock.foot_forward_positions_in_yaw_frame(self, self._foot_asset_cfg)
+        foot_lateral = symmetry_clock.foot_lateral_positions_in_yaw_frame(self, self._foot_asset_cfg)
+        self._foot_lateral_mirror_sq += torch.square(foot_lateral[:, 0] + foot_lateral[:, 1]) * move_mask
+        self._half_cycle_corr_num += foot_forward[:, 0] * (-foot_forward[:, 1])
+        self._half_cycle_corr_left_sq += torch.square(foot_forward[:, 0])
+        self._half_cycle_corr_right_sq += torch.square(foot_forward[:, 1])
+        robot = self.scene["robot"]
+        self._leg_joint_mirror_sq += full_body_symmetry.leg_joint_half_cycle_error_from_env(self, robot) * move_mask
+        self._arm_joint_mirror_sq += full_body_symmetry.arm_joint_mirror_error_from_env(self, robot) * move_mask
+
+    def _collect_symmetry_logs(self, env_ids: torch.Tensor) -> dict[str, float]:
+        clearance = self._swing_height_sum / torch.clamp(self._swing_weight_sum, min=symmetry_clock.EPS)
+        correlation = self._half_cycle_corr_num / torch.sqrt(
+            self._half_cycle_corr_left_sq * self._half_cycle_corr_right_sq + symmetry_clock.EPS
+        )
+        logs = {
+            "Episode_Symmetry/stance_time_asymmetry": _mean(
+                _asymmetry_ratio(self._stance_time[:, 0], self._stance_time[:, 1]), env_ids
+            ),
+            "Episode_Symmetry/step_clearance_asymmetry": _mean(
+                _asymmetry_ratio(clearance[:, 0], clearance[:, 1]), env_ids
+            ),
+            "Episode_Symmetry/ground_impulse_asymmetry": _mean(
+                _asymmetry_ratio(self._ground_impulse[:, 0], self._ground_impulse[:, 1]), env_ids
+            ),
+            "Episode_Symmetry/foot_lateral_mirror_error": _mean(
+                _rms(self._foot_lateral_mirror_sq, self._moving_step_weight), env_ids
+            ),
+            "Episode_Symmetry/half_cycle_shifted_foot_correlation": _mean(
+                torch.clamp(correlation, min=-1.0, max=1.0), env_ids
+            ),
+            "Episode_Symmetry/leg_joint_half_cycle_mirror_error": _mean(
+                _rms(self._leg_joint_mirror_sq, self._moving_step_weight), env_ids
+            ),
+            "Episode_Symmetry/arm_joint_mirror_error": _mean(
+                _rms(self._arm_joint_mirror_sq, self._moving_step_weight), env_ids
+            ),
+        }
+        logs.update(_action_symmetry_logs(self, env_ids))
+        return logs
+
+    def _clear_metric_buffers(self, env_ids: torch.Tensor) -> None:
+        self._stance_time[env_ids] = 0.0
+        self._ground_impulse[env_ids] = 0.0
+        self._swing_height_sum[env_ids] = 0.0
+        self._swing_weight_sum[env_ids] = 0.0
+        self._moving_step_weight[env_ids] = 0.0
+        self._foot_lateral_mirror_sq[env_ids] = 0.0
+        self._half_cycle_corr_num[env_ids] = 0.0
+        self._half_cycle_corr_left_sq[env_ids] = 0.0
+        self._half_cycle_corr_right_sq[env_ids] = 0.0
+        self._leg_joint_mirror_sq[env_ids] = 0.0
+        self._arm_joint_mirror_sq[env_ids] = 0.0
+        velocity_metrics.clear_velocity_metric_buffers(self, env_ids)
+        velocity_metrics.assign_standalone_gait_phase_offsets(self, env_ids)
+
+    def _make_scene_entity_cfg(self, scene_name: str) -> SceneEntityCfg:
+        entity = self.scene[scene_name] if scene_name == "robot" else self.scene.sensors[scene_name]
+        body_ids, _ = entity.find_bodies(["left_foot_link", "right_foot_link"], preserve_order=True)
+        return SceneEntityCfg(scene_name, body_ids=body_ids)
+
+    def _init_symmetry_metric_buffers(self) -> None:
+        self._stance_time = torch.zeros(self.num_envs, 2, device=self.device)
+        self._ground_impulse = torch.zeros(self.num_envs, 2, device=self.device)
+        self._swing_height_sum = torch.zeros(self.num_envs, 2, device=self.device)
+        self._swing_weight_sum = torch.zeros(self.num_envs, 2, device=self.device)
+        self._moving_step_weight = torch.zeros(self.num_envs, device=self.device)
+        self._foot_lateral_mirror_sq = torch.zeros(self.num_envs, device=self.device)
+        self._half_cycle_corr_num = torch.zeros(self.num_envs, device=self.device)
+        self._half_cycle_corr_left_sq = torch.zeros(self.num_envs, device=self.device)
+        self._half_cycle_corr_right_sq = torch.zeros(self.num_envs, device=self.device)
+        self._leg_joint_mirror_sq = torch.zeros(self.num_envs, device=self.device)
+        self._arm_joint_mirror_sq = torch.zeros(self.num_envs, device=self.device)
+
+    def _to_env_tensor(self, env_ids: Sequence[int] | torch.Tensor) -> torch.Tensor:
+        if isinstance(env_ids, torch.Tensor):
+            return env_ids.to(device=self.device, dtype=torch.long)
+        return torch.tensor(list(env_ids), device=self.device, dtype=torch.long)
+
+
+def _asymmetry_ratio(left: torch.Tensor, right: torch.Tensor) -> torch.Tensor:
+    return torch.abs(left - right) / (torch.abs(left) + torch.abs(right) + symmetry_clock.EPS)
+
+
+def _mean(values: torch.Tensor, env_ids: torch.Tensor) -> float:
+    if env_ids.numel() == 0:
+        return 0.0
+    return values[env_ids].mean().item()
+
+
+def _action_symmetry_logs(env: T1PhaseRecurrentEnv, env_ids: torch.Tensor) -> dict[str, float]:
+    action_term = env.action_manager.get_term("joint_pos")
+    if not hasattr(action_term, "paired_action_mse"):
+        return {}
+    return {"Episode_Symmetry/paired_action_mse": _mean(action_term.paired_action_mse, env_ids)}
+
+
+def _rms(values: torch.Tensor, weights: torch.Tensor) -> torch.Tensor:
+    return torch.sqrt(values / torch.clamp(weights, min=symmetry_clock.EPS))
