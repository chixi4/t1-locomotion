+++ b/source/isaaclab_tasks/isaaclab_tasks/manager_based/locomotion/velocity/mdp/symmetry/t1.py
@@ -0,0 +1,135 @@
+# Copyright (c) 2022-2026, The Isaac Lab Project Developers.
+# All rights reserved.
+#
+# SPDX-License-Identifier: BSD-3-Clause
+
+"""Symmetry functions for the T1 velocity task."""
+
+from __future__ import annotations
+
+from typing import TYPE_CHECKING
+
+import torch
+from tensordict import TensorDict
+
+if TYPE_CHECKING:
+    from isaaclab.envs import ManagerBasedRLEnv
+
+__all__ = [
+    "compute_symmetric_states",
+    "mirror_joint_tensor",
+    "mirror_policy_obs",
+    "mirror_action",
+    "unmirror_action",
+    "mirror_velocity_command",
+]
+
+JOINT_COUNT = 23
+POLICY_OBS_BASE_SIZE = 81
+POLICY_OBS_WITH_PHASE_SIZE = 83
+
+BASE_LIN_VEL = slice(0, 3)
+BASE_ANG_VEL = slice(3, 6)
+PROJECTED_GRAVITY = slice(6, 9)
+VELOCITY_COMMAND = slice(9, 12)
+JOINT_POS = slice(12, 35)
+JOINT_VEL = slice(35, 58)
+LAST_ACTION = slice(58, 81)
+PHASE_CLOCK = slice(81, 83)
+
+LEFT_RIGHT_PAIRS = (
+    (2, 6),
+    (3, 7),
+    (4, 8),
+    (5, 9),
+    (11, 17),
+    (12, 18),
+    (13, 19),
+    (14, 20),
+    (15, 21),
+    (16, 22),
+)
+NEGATE_AFTER_SWAP = torch.tensor([0, 3, 5, 7, 9, 10, 12, 13, 16, 18, 19, 22], dtype=torch.long)
+
+
+@torch.no_grad()
+def compute_symmetric_states(
+    env: ManagerBasedRLEnv,
+    obs: TensorDict | None = None,
+    actions: torch.Tensor | None = None,
+):
+    """Apply a left-right mirror transform for the T1 humanoid."""
+
+    if obs is not None:
+        obs_aug = obs.repeat(2)
+        batch_size = obs.batch_size[0]
+        obs_aug["policy"][:batch_size] = obs["policy"]
+        obs_aug["policy"][batch_size:] = mirror_policy_obs(obs["policy"])
+    else:
+        obs_aug = None
+
+    if actions is not None:
+        _validate_action_shape(actions)
+        batch_size = actions.shape[0]
+        actions_aug = torch.zeros(batch_size * 2, actions.shape[1], device=actions.device)
+        actions_aug[:batch_size] = actions
+        actions_aug[batch_size:] = mirror_joint_tensor(actions)
+    else:
+        actions_aug = None
+
+    return obs_aug, actions_aug
+
+
+def mirror_policy_obs(obs: torch.Tensor) -> torch.Tensor:
+    if obs.shape[1] not in {POLICY_OBS_BASE_SIZE, POLICY_OBS_WITH_PHASE_SIZE}:
+        raise ValueError(
+            "Expected T1 policy observation size "
+            f"{POLICY_OBS_BASE_SIZE} or {POLICY_OBS_WITH_PHASE_SIZE}, got {obs.shape[1]}."
+        )
+
+    mirrored = obs.clone()
+    device = obs.device
+    mirrored[:, BASE_LIN_VEL] = obs[:, BASE_LIN_VEL] * torch.tensor([1.0, -1.0, 1.0], device=device)
+    mirrored[:, BASE_ANG_VEL] = obs[:, BASE_ANG_VEL] * torch.tensor([-1.0, 1.0, -1.0], device=device)
+    mirrored[:, PROJECTED_GRAVITY] = obs[:, PROJECTED_GRAVITY] * torch.tensor([1.0, -1.0, 1.0], device=device)
+    mirrored[:, VELOCITY_COMMAND] = mirror_velocity_command(obs[:, VELOCITY_COMMAND])
+    mirrored[:, JOINT_POS] = mirror_joint_tensor(obs[:, JOINT_POS])
+    mirrored[:, JOINT_VEL] = mirror_joint_tensor(obs[:, JOINT_VEL])
+    mirrored[:, LAST_ACTION] = mirror_joint_tensor(obs[:, LAST_ACTION])
+    if obs.shape[1] == POLICY_OBS_WITH_PHASE_SIZE:
+        mirrored[:, PHASE_CLOCK] = -obs[:, PHASE_CLOCK]
+    return mirrored
+
+
+def mirror_joint_tensor(joint_tensor: torch.Tensor) -> torch.Tensor:
+    if joint_tensor.shape[1] != JOINT_COUNT:
+        raise ValueError(f"Expected T1 joint tensor width {JOINT_COUNT}, got {joint_tensor.shape[1]}.")
+
+    mirrored = joint_tensor.clone()
+    for left_index, right_index in LEFT_RIGHT_PAIRS:
+        mirrored[:, left_index] = joint_tensor[:, right_index]
+        mirrored[:, right_index] = joint_tensor[:, left_index]
+    mirrored[:, NEGATE_AFTER_SWAP.to(joint_tensor.device)] *= -1.0
+    return mirrored
+
+
+def mirror_action(actions: torch.Tensor) -> torch.Tensor:
+    _validate_action_shape(actions)
+    return mirror_joint_tensor(actions)
+
+
+def unmirror_action(actions: torch.Tensor) -> torch.Tensor:
+    _validate_action_shape(actions)
+    return mirror_joint_tensor(actions)
+
+
+def mirror_velocity_command(command: torch.Tensor) -> torch.Tensor:
+    if command.shape[-1] != 3:
+        raise ValueError(f"Expected velocity command width 3, got {command.shape[-1]}.")
+    signs = torch.tensor([1.0, -1.0, -1.0], device=command.device, dtype=command.dtype)
+    return command * signs
+
+
+def _validate_action_shape(actions: torch.Tensor) -> None:
+    if actions.ndim != 2:
+        raise ValueError(f"Expected 2D action tensor for T1 symmetry, got shape {tuple(actions.shape)}.")
