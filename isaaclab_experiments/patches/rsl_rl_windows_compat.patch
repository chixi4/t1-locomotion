@@ -0,0 +1,17 @@
+"""Windows-specific bootstrap helpers for RSL-RL scripts."""
+
+import platform
+
+
+def warm_up_windows_rsl_rl_imports() -> None:
+    """Preload native RSL-RL dependencies before Isaac Sim mutates DLL state.
+
+    On Windows, importing TensorDict after SimulationApp startup can crash inside
+    its native extension. Importing it first keeps the extension load order
+    stable and lets the later RSL-RL imports succeed.
+    """
+
+    if platform.system() != "Windows":
+        return
+
+    import tensordict  # noqa: F401
