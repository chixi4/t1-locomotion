+def _pad_loaded_input_weight(key: str, loaded_tensor: torch.Tensor, target_tensor: torch.Tensor) -> torch.Tensor:
+    if loaded_tensor.ndim != 2 or target_tensor.ndim != 2:
+        raise ValueError(f"Expected 2D tensors for padded resume on '{key}', got {loaded_tensor.shape} -> {target_tensor.shape}.")
+    if loaded_tensor.shape[0] != target_tensor.shape[0]:
+        raise ValueError(f"Cannot adapt '{key}' because output dimensions differ: {loaded_tensor.shape} -> {target_tensor.shape}.")
+    if loaded_tensor.shape[1] > target_tensor.shape[1]:
+        raise ValueError(f"Cannot adapt '{key}' because checkpoint input is wider than target: {loaded_tensor.shape} -> {target_tensor.shape}.")
+
+    padded_tensor = torch.zeros_like(target_tensor)
+    padded_tensor[:, : loaded_tensor.shape[1]] = loaded_tensor
+    return padded_tensor
+
+
+def _load_policy_weights_only(runner: OnPolicyRunner, checkpoint_path: str):
+    loaded_dict = torch.load(checkpoint_path, weights_only=False, map_location=runner.device)
+    loaded_state = loaded_dict["model_state_dict"]
+    target_state = runner.alg.policy.state_dict()
+    adapted_state = {}
+
+    for key, target_tensor in target_state.items():
+        if key not in loaded_state:
+            raise KeyError(f"Checkpoint is missing policy parameter '{key}'.")
+        loaded_tensor = loaded_state[key]
+        if loaded_tensor.shape == target_tensor.shape:
+            adapted_state[key] = loaded_tensor
+            continue
+        if key not in ADAPTABLE_POLICY_INPUT_KEYS:
+            raise ValueError(
+                f"Unsupported checkpoint shape mismatch for '{key}': {loaded_tensor.shape} -> {target_tensor.shape}."
+            )
+        adapted_state[key] = _pad_loaded_input_weight(key, loaded_tensor, target_tensor)
+        print(f"[INFO]: Adapted checkpoint tensor '{key}' from {tuple(loaded_tensor.shape)} to {tuple(target_tensor.shape)}.")
+
+    unexpected_keys = sorted(set(loaded_state) - set(target_state))
+    if unexpected_keys:
+        print(f"[INFO]: Ignoring {len(unexpected_keys)} unexpected checkpoint keys during model-only load.")
+
+    runner.alg.policy.load_state_dict(adapted_state, strict=True)
+    return loaded_dict.get("infos")
 
 
